_loop(bidi) end\nspawn do send_loop(bidi) end\n\nbegin\n  yield\nensure\n  @running.set(0)\n  begin\n    bidi.close_send\n  rescue\n    nil\n  end\n  begin\n    bidi.cancel\n  rescue\n    nil\n  end\n  read_cache.clear\n  @action_mutex.synchronize do   @action_queue.clear\n  @sent_actions.clear\n end\nend\n"},"external_var":false},{"html_id":"running?:Bool-instance-method","name":"running?","abstract":false,"location":{"filename":"src/read_until.cr","line_number":159,"url":"https://github.com/kojix2/read_until/blob/01cf9b210f3c834de3e3f8b95a17bb2a1b39c4d8/src/read_until.cr#L159"},"def":{"name":"running?","return_type":"Bool","visibility":"Public","body":"@running.get == 1"},"external_var":false},{"html_id":"stop:Nil-instance-method","name":"stop","doc":"Signals the stream to stop without blocking.","summary":"<p>Signals the stream to stop without blocking.</p>","abstract":false,"location":{"filename":"src/read_until.cr","line_number":219,"url":"https://github.com/kojix2/read_until/blob/01cf9b210f3c834de3e3f8b95a17bb2a1b39c4d8/src/read_until.cr#L219"},"def":{"name":"stop","return_type":"Nil","visibility":"Public","body":"@running.set(0)"},"external_var":false},{"html_id":"stop_receiving(channel:Int32,read_id:String):Nil-instance-method","name":"stop_receiving","doc":"Queues a stop-further-data request for *read_id* on *channel*.","summary":"<p>Queues a stop-further-data request for <em>read_id</em> on <em>channel</em>.</p>","abstract":false,"args":[{"name":"channel","external_name":"channel","restriction":"Int32"},{"name":"read_id","external_name":"read_id","restriction":"String"}],"args_string":"(channel : Int32, read_id : String) : Nil","args_html":"(channel : Int32, read_id : String) : Nil","location":{"filename":"src/read_until.cr","line_number":185,"url":"https://github.com/kojix2/read_until/blob/01cf9b210f3c834de3e3f8b95a17bb2a1b39c4d8/src/read_until.cr#L185"},"def":{"name":"stop_receiving","args":[{"name":"channel","external_name":"channel","restriction":"Int3